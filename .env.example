# --- MariaDB ---
MARIADB_ROOT_PASSWORD=conspectare_root
MARIADB_DATABASE=conspectare
MARIADB_USER=conspectare
MARIADB_PASSWORD=conspectare_pass

# --- Database connection (required) ---
ConnectionStrings__ConspectareDb=Server=db;Port=3306;Database=conspectare;Uid=conspectare;Pwd=conspectare_pass;

# --- AWS / S3 (required) ---
Aws__AccessKeyId=test
Aws__SecretAccessKey=test
Aws__Region=eu-central-1
Aws__BucketName=docpipeline-dev
Aws__ServiceUrl=http://localstack:4566

# --- LLM Provider ---
Llm__Provider=claude
# Llm__MultiModel__Enabled=false

# --- Claude (required when Llm__Provider=claude or MultiModel enabled) ---
Claude__ApiKey=

# --- Gemini (required when Llm__Provider=gemini or MultiModel enabled) ---
Gemini__ApiKey=
Gemini__Model=gemini-3.1-pro

# --- ANAF VAT Validation ---
Anaf__BaseUrl=https://webservicesp.anaf.ro/PlatitorTvaRest
Anaf__TimeoutSeconds=10
Anaf__MaxRetries=2

# --- P&L Integration (dev seed only) ---
PNL_API_URL=http://localhost:5200
PNL_WEBHOOK_SECRET=whsec_dev_placeholder
